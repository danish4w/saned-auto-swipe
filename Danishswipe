name: danishSwipe
on: workflow_dispatch
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Java
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'
      
      - name: Setup Android SDK
        uses: android-actions/setup-android@v3
      
      - name: Create App
        run: |
          mkdir -p app/src/main/java/com/saned/autoswipe
          mkdir -p app/src/main/res/layout
          mkdir -p app/src/main/res/values
          mkdir -p app/src/main/res/xml
          
          echo 'buildscript {
              ext.kotlin_version = "1.9.0"
              repositories { google() mavenCentral() }
              dependencies {
                  classpath "com.android.tools.build:gradle:8.1.0"
                  classpath "org.jetbrains.kotlin:kotlin-gradle-plugin:$kotlin_version"
              }
          }' > build.gradle
          
          echo 'rootProject.name = "SanedAutoSwipe"
          include ":app"' > settings.gradle
          
          echo 'plugins {
              id "com.android.application"
              id "org.jetbrains.kotlin.android"
          }
          android {
              namespace "com.saned.autoswipe"
              compileSdk 34
              defaultConfig {
                  applicationId "com.saned.autoswipe"
                  minSdk 26
                  targetSdk 34
                  versionCode 1
                  versionName "1.0"
              }
              buildFeatures {
                  viewBinding true
              }
              compileOptions {
                  sourceCompatibility JavaVersion.VERSION_17
                  targetCompatibility JavaVersion.VERSION_17
              }
              kotlinOptions { jvmTarget = "17" }
          }
          dependencies {
              implementation "androidx.core:core-ktx:1.12.0"
              implementation "androidx.appcompat:appcompat:1.6.1"
              implementation "com.google.android.material:material:1.11.0"
              implementation "androidx.constraintlayout:constraintlayout:2.1.4"
          }' > app/build.gradle
          
          echo '<?xml version="1.0" encoding="utf-8"?>
          <manifest xmlns:android="http://schemas.android.com/apk/res/android">
              <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
              <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
              <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
              <application android:allowBackup="true" android:label="@string/app_name" android:theme="@style/Theme.SanedAutoSwipe">
                  <activity android:name=".MainActivity" android:exported="true">
                      <intent-filter>
                          <action android:name="android.intent.action.MAIN"/>
                          <category android:name="android.intent.category.LAUNCHER"/>
                      </intent-filter>
                  </activity>
                  <service android:name=".AutoSwipeService" android:exported="true" android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
                      <intent-filter>
                          <action android:name="android.accessibilityservice.AccessibilityService"/>
                      </intent-filter>
                      <meta-data android:name="android.accessibilityservice" android:resource="@xml/accessibility_service_config"/>
                  </service>
              </application>
          </manifest>' > app/src/main/AndroidManifest.xml
          
          echo '<resources>
              <string name="app_name">Saned Auto Swipe</string>
          </resources>' > app/src/main/res/values/strings.xml
          
          echo '<?xml version="1.0" encoding="utf-8"?>
          <resources>
              <color name="white">#FFFFFF</color>
              <color name="purple_500">#6200EE</color>
          </resources>' > app/src/main/res/values/colors.xml
          
          echo '<resources>
              <style name="Theme.SanedAutoSwipe" parent="Theme.MaterialComponents.DayNight.NoActionBar">
                  <item name="colorPrimary">#6200EE</item>
                  <item name="android:statusBarColor">#6200EE</item>
              </style>
          </resources>' > app/src/main/res/values/themes.xml
          
          echo '<?xml version="1.0" encoding="utf-8"?>
          <accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
              android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged"
              android:accessibilityFeedbackType="feedbackGeneric"
              android:accessibilityFlags="flagRetrieveInteractiveWindows"
              android:canPerformGestures="true"
              android:canRetrieveWindowContent="true"
              android:notificationTimeout="500" />' > app/src/main/res/xml/accessibility_service_config.xml
          
          echo '<?xml version="1.0" encoding="utf-8"?>
          <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:app="http://schemas.android.com/apk/res-auto"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:padding="16dp"
              android:background="#1a1a2e">
              <LinearLayout android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="vertical">
                  <TextView android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:text="🚗 Saned Auto Swipe"
                      android:textSize="28sp"
                      android:textStyle="bold"
                      android:textColor="#FFFFFF"
                      android:gravity="center"
                      android:layout_marginBottom="24dp" />
                  <TextView android:id="@+id/serviceStatus"
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:text="⚫ INACTIVE"
                      android:textSize="18sp"
                      android:textStyle="bold"
                      android:gravity="center"
                      android:padding="12dp"
                      android:background="#16213e"
                      android:layout_marginBottom="20dp" />
                  <Button android:id="@+id/btnAccessibility"
                      android:layout_width="match_parent"
                      android:layout_height="60dp"
                      android:text="⚠️ Enable Accessibility"
                      android:textSize="16sp"
                      android:textStyle="bold"
                      android:layout_marginBottom="20dp" />
                  <TextView android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="📍 Pickup Distance Limit"
                      android:textColor="#FFFFFF"
                      android:textSize="16sp"
                      android:layout_marginBottom="8dp" />
                  <TextView android:id="@+id/pickupText"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Max Pickup: 3.0 km"
                      android:textColor="#aaaaff"
                      android:layout_marginBottom="8dp" />
                  <Slider android:id="@+id/pickupSlider"
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:valueFrom="0.1"
                      android:valueTo="10.0"
                      android:stepSize="0.1"
                      android:value="3.0"
                      android:layout_marginBottom="20dp" />
                  <TextView android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="🏁 Drop Distance Limit"
                      android:textColor="#FFFFFF"
                      android:textSize="16sp"
                      android:layout_marginBottom="8dp" />
                  <TextView android:id="@+id/dropText"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Max Drop: 5.0 km"
                      android:textColor="#aaaaff"
                      android:layout_marginBottom="8dp" />
                  <Slider android:id="@+id/dropSlider"
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:valueFrom="0.1"
                      android:valueTo="10.0"
                      android:stepSize="0.1"
                      android:value="5.0"
                      android:layout_marginBottom="20dp" />
                  <LinearLayout android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:orientation="horizontal"
                      android:layout_marginBottom="24dp">
                      <TextView android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1"
                          android:text="🔔 Notifications"
                          android:textColor="#FFFFFF"
                          android:textSize="16sp" />
                      <com.google.android.material.switchmaterial.SwitchMaterial
                          android:id="@+id/notificationSwitch"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:checked="true" />
                  </LinearLayout>
                  <Button android:id="@+id/btnStartStop"
                      android:layout_width="match_parent"
                      android:layout_height="65dp"
                      android:text="▶ START"
                      android:textSize="20sp"
                      android:textStyle="bold"
                      android:backgroundTint="#4CAF50" />
                  <TextView android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginTop="24dp"
                      android:text="ℹ️ How it works:\n\n1. Enable Accessibility permission\n2. Set your distance limits (0.1-10 km)\n3. Press START\n4. Open Saned app\n5. Orders within limits will be auto-accepted"
                      android:textColor="#888888"
                      android:textSize="12sp"
                      android:lineSpacingExtra="4dp"
                      android:padding="12dp"
                      android:background="#16213e" />
              </LinearLayout>
          </ScrollView>' > app/src/main/res/layout/activity_main.xml
          
          echo 'package com.saned.autoswipe
          
          import android.content.Context
          import android.content.Intent
          import android.os.Build
          import android.os.Bundle
          import android.provider.Settings
          import android.widget.Button
          import android.widget.TextView
          import android.widget.Toast
          import androidx.appcompat.app.AppCompatActivity
          import com.google.android.material.switchmaterial.SwitchMaterial
          import com.google.android.material.slider.Slider
          
          class MainActivity : AppCompatActivity() {
              private lateinit var btnAccessibility: Button
              private lateinit var btnStartStop: Button
              private lateinit var pickupSlider: Slider
              private lateinit var dropSlider: Slider
              private lateinit var pickupText: TextView
              private lateinit var dropText: TextView
              private lateinit var serviceStatus: TextView
              private lateinit var notificationSwitch: SwitchMaterial
              private var isServiceRunning = false
              
              override fun onCreate(savedInstanceState: Bundle?) {
                  super.onCreate(savedInstanceState)
                  setContentView(R.layout.activity_main)
                  initViews()
                  loadSettings()
                  updateUI()
                  checkAccessibilityPermission()
              }
              
              private fun initViews() {
                  btnAccessibility = findViewById(R.id.btnAccessibility)
                  btnStartStop = findViewById(R.id.btnStartStop)
                  pickupSlider = findViewById(R.id.pickupSlider)
                  dropSlider = findViewById(R.id.dropSlider)
                  pickupText = findViewById(R.id.pickupText)
                  dropText = findViewById(R.id.dropText)
                  serviceStatus = findViewById(R.id.serviceStatus)
                  notificationSwitch = findViewById(R.id.notificationSwitch)
                  
                  btnAccessibility.setOnClickListener { openAccessibilitySettings() }
                  btnStartStop.setOnClickListener { if (isServiceRunning) stopService() else startService() }
                  pickupSlider.addOnChangeListener { _, value, _ ->
                      pickupText.text = "Max Pickup: ${String.format("%.1f", value)} km"
                      saveSettings()
                  }
                  dropSlider.addOnChangeListener { _, value, _ ->
                      dropText.text = "Max Drop: ${String.format("%.1f", value)} km"
                      saveSettings()
                  }
                  notificationSwitch.setOnCheckedChangeListener { _, _ -> saveSettings() }
              }
              
              private fun loadSettings() {
                  val prefs = getSharedPreferences("saned_settings", Context.MODE_PRIVATE)
                  pickupSlider.value = prefs.getFloat("max_pickup", 3.0f)
                  dropSlider.value = prefs.getFloat("max_drop", 5.0f)
                  notificationSwitch.isChecked = prefs.getBoolean("notifications", true)
                  pickupText.text = "Max Pickup: ${String.format("%.1f", pickupSlider.value)} km"
                  dropText.text = "Max Drop: ${String.format("%.1f", dropSlider.value)} km"
              }
              
              private fun saveSettings() {
                  val prefs = getSharedPreferences("saned_settings", Context.MODE_PRIVATE)
                  prefs.edit().putFloat("max_pickup", pickupSlider.value)
                      .putFloat("max_drop", dropSlider.value)
                      .putBoolean("notifications", notificationSwitch.isChecked).apply()
              }
              
              private fun checkAccessibilityPermission() {
                  val isEnabled = isAccessibilityServiceEnabled()
                  if (isEnabled) {
                      btnAccessibility.text = "✅ Accessibility Active"
                      btnAccessibility.setBackgroundColor(getColor(android.R.color.holo_green_dark))
                  } else {
                      btnAccessibility.text = "⚠️ Enable Accessibility"
                      btnAccessibility.setBackgroundColor(getColor(android.R.color.holo_red_dark))
                  }
              }
              
              private fun isAccessibilityServiceEnabled(): Boolean {
                  val service = "${packageName}/${AutoSwipeService::class.java.canonicalName}"
                  return try {
                      Settings.Secure.getString(contentResolver, Settings.Secure.ENABLED_ACCESSIBILITY_SERVICES)?.contains(service) == true
                  } catch(e: Exception) { false }
              }
              
              private fun openAccessibilitySettings() {
                  startActivity(Intent(Settings.ACTION_ACCESSIBILITY_SETTINGS))
              }
              
              private fun startService() {
                  if (!isAccessibilityServiceEnabled()) {
                      Toast.makeText(this, "Please enable accessibility service first!", Toast.LENGTH_LONG).show()
                      return
                  }
                  val intent = Intent(this, AutoSwipeService::class.java).apply {
                      putExtra("max_pickup", pickupSlider.value)
                      putExtra("max_drop", dropSlider.value)
                      putExtra("notifications", notificationSwitch.isChecked)
                  }
                  if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
                      startForegroundService(intent)
                  } else {
                      startService(intent)
                  }
                  isServiceRunning = true
                  updateUI()
                  Toast.makeText(this, "✅ Auto Swipe Started", Toast.LENGTH_SHORT).show()
              }
              
              private fun stopService() {
                  stopService(Intent(this, AutoSwipeService::class.java))
                  isServiceRunning = false
                  updateUI()
                  Toast.makeText(this, "⏹️ Auto Swipe Stopped", Toast.LENGTH_SHORT).show()
              }
              
              private fun updateUI() {
                  if (isServiceRunning) {
                      btnStartStop.text = "⏹️ STOP"
                      btnStartStop.setBackgroundColor(getColor(android.R.color.holo_red_dark))
                      serviceStatus.text = "🟢 ACTIVE - Monitoring Orders"
                      serviceStatus.setTextColor(getColor(android.R.color.holo_green_dark))
                  } else {
                      btnStartStop.text = "▶ START"
                      btnStartStop.setBackgroundColor(getColor(android.R.color.holo_green_dark))
                      serviceStatus.text = "⚫ INACTIVE - Press START"
                      serviceStatus.setTextColor(getColor(android.R.color.darker_gray))
                  }
              }
              
              override fun onResume() {
                  super.onResume()
                  checkAccessibilityPermission()
              }
          }' > app/src/main/java/com/saned/autoswipe/MainActivity.kt
          
          echo 'package com.saned.autoswipe
          
          import android.accessibilityservice.AccessibilityService
          import android.accessibilityservice.AccessibilityServiceInfo
          import android.app.NotificationChannel
          import android.app.NotificationManager
          import android.app.PendingIntent
          import android.content.Context
          import android.content.Intent
          import android.content.SharedPreferences
          import android.os.Build
          import android.os.Handler
          import android.os.Looper
          import android.util.Log
          import android.view.accessibility.AccessibilityEvent
          import android.view.accessibility.AccessibilityNodeInfo
          import androidx.core.app.NotificationCompat
          
          class AutoSwipeService : AccessibilityService() {
              private lateinit var prefs: SharedPreferences
              private var maxPickup = 3.0
              private var maxDrop = 5.0
              private var sendNotifications = true
              private var isProcessing = false
              private val handler = Handler(Looper.getMainLooper())
              
              companion object {
                  private const val CHANNEL_ID = "auto_swipe_channel"
                  private const val NOTIFICATION_ID = 1001
              }
              
              override fun onCreate() {
                  super.onCreate()
                  prefs = getSharedPreferences("saned_settings", Context.MODE_PRIVATE)
                  createNotificationChannel()
              }
              
              override fun onServiceConnected() {
                  super.onServiceConnected()
                  val info = AccessibilityServiceInfo().apply {
                      eventTypes = AccessibilityEvent.TYPE_WINDOW_CONTENT_CHANGED or AccessibilityEvent.TYPE_WINDOW_STATE_CHANGED
                      feedbackType = AccessibilityServiceInfo.FEEDBACK_GENERIC
                      flags = AccessibilityServiceInfo.FLAG_RETRIEVE_INTERACTIVE_WINDOWS
                      notificationTimeout = 500
                  }
                  setServiceInfo(info)
                  showNotification("Auto Swipe Active", "Monitoring Saned orders...")
              }
              
              override fun onStartCommand(intent: Intent?, flags: Int, startId: Int): Int {
                  maxPickup = prefs.getFloat("max_pickup", 3.0f).toDouble()
                  maxDrop = prefs.getFloat("max_drop", 5.0f).toDouble()
                  sendNotifications = prefs.getBoolean("notifications", true)
                  return START_STICKY
              }
              
              override fun onAccessibilityEvent(event: AccessibilityEvent?) {
                  if (isProcessing) return
                  event?.let {
                      if (it.packageName?.toString() == "net.jahez.fleets") {
                          checkForOrder()
                      }
                  }
              }
              
              private fun checkForOrder() {
                  val root = rootInActiveWindow ?: return
                  if (findTextInNode(root, "New Order") != null) {
                      extractAndCheckDistances(root)
                  }
              }
              
              private fun extractAndCheckDistances(root: AccessibilityNodeInfo) {
                  val pickupDistance = extractDistance(root, "From You")
                  val dropDistance = extractDistance(root, "From Pickup")
                  
                  if (pickupDistance != null && dropDistance != null) {
                      if (pickupDistance <= maxPickup && dropDistance <= maxDrop) {
                          performSwipe()
                      }
                  }
              }
              
              private fun extractDistance(root: AccessibilityNodeInfo, keyword: String): Double? {
                  val textNode = findTextContaining(root, keyword)
                  if (textNode != null) {
                      val text = textNode.text?.toString() ?: return null
                      val regex = Regex("(\\d+\\.?\\d*)\\s*[Kk][Mm]")
                      val match = regex.find(text)
                      return match?.groupValues?.get(1)?.toDoubleOrNull()
                  }
                  return null
              }
              
              private fun findTextInNode(node: AccessibilityNodeInfo, target: String): AccessibilityNodeInfo? {
                  if (node.text?.toString()?.contains(target, ignoreCase = true) == true) return node
                  for (i in 0 until node.childCount) {
                      val child = node.getChild(i) ?: continue
                      val result = findTextInNode(child, target)
                      if (result != null) return result
                  }
                  return null
              }
              
              private fun findTextContaining(node: AccessibilityNodeInfo, keyword: String): AccessibilityNodeInfo? {
                  if (node.text?.toString()?.contains(keyword, ignoreCase = true) == true) return node
                  for (i in 0 until node.childCount) {
                      val child = node.getChild(i) ?: continue
                      val result = findTextContaining(child, keyword)
                      if (result != null) return result
                  }
                  return null
              }
              
              private fun performSwipe() {
                  isProcessing = true
                  handler.postDelayed({
                      try {
                          val root = rootInActiveWindow
                          if (root != null) {
                              fun findButton(node: AccessibilityNodeInfo, texts: List<String>): AccessibilityNodeInfo? {
                                  if (node.isClickable && node.text?.toString() != null) {
                                      for (text in texts) {
                                          if (node.text.toString().contains(text, ignoreCase = true)) return node
                                      }
                                  }
                                  for (i in 0 until node.childCount) {
                                      val child = node.getChild(i) ?: continue
                                      val result = findButton(child, texts)
                                      if (result != null) return result
                                  }
                                  return null
                              }
                              val acceptButton = findButton(root, listOf("Accept", "ACCEPT", "Confirm", "CONFIRM", "Take", "TAKE"))
                              if (acceptButton != null && acceptButton.isClickable) {
                                  acceptButton.performAction(AccessibilityNodeInfo.ACTION_CLICK)
                                  showNotification("✅ Order Accepted!", "Auto accepted within your limits")
                                  handler.postDelayed({ stopSelf() }, 2000)
                              }
                          }
                      } catch(e: Exception) {
                          Log.e("AutoSwipe", "Error: ${e.message}")
                      }
                      isProcessing = false
                  }, 1000)
              }
              
              private fun showNotification(title: String, content: String) {
                  if (!sendNotifications) return
                  val intent = Intent(this, MainActivity::class.java)
                  val pendingIntent = PendingIntent.getActivity(this, 0, intent, PendingIntent.FLAG_UPDATE_CURRENT or PendingIntent.FLAG_IMMUTABLE)
                  val notification = NotificationCompat.Builder(this, CHANNEL_ID)
                      .setContentTitle(title)
                      .setContentText(content)
                      .setSmallIcon(android.R.drawable.ic_dialog_info)
                      .setContentIntent(pendingIntent)
                      .setAutoCancel(true)
                      .build()
                  val manager = getSystemService(Context.NOTIFICATION_SERVICE) as NotificationManager
                  manager.notify(NOTIFICATION_ID, notification)
              }
              
              private fun createNotificationChannel() {
                  if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
                      val channel = NotificationChannel(CHANNEL_ID, "Auto Swipe Service", NotificationManager.IMPORTANCE_HIGH)
                      val manager = getSystemService(NotificationManager::class.java)
                      manager.createNotificationChannel(channel)
                      val notification = NotificationCompat.Builder(this, CHANNEL_ID)
                          .setContentTitle("Saned Auto Swipe")
                          .setContentText("Monitoring orders...")
                          .setSmallIcon(android.R.drawable.ic_dialog_info)
                          .build()
                      startForeground(NOTIFICATION_ID, notification)
                  }
              }
              
              override fun onInterrupt() {}
          }' > app/src/main/java/com/saned/autoswipe/AutoSwipeService.kt
      
      - name: Build APK
        run: |
          echo "sdk.dir=$ANDROID_HOME" > local.properties
          mkdir -p gradle/wrapper
          echo "distributionUrl=https://services.gradle.org/distributions/gradle-8.0-bin.zip" > gradle/wrapper/gradle-wrapper.properties
          chmod +x gradlew 2>/dev/null || true
          ./gradlew assembleDebug --no-daemon || true
      
      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: Saned-Auto-Swipe-Final
          path: app/build/outputs/apk/debug/*.apk
